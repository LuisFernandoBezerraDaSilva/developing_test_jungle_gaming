# API REST via Kong (rotas /games e /wallets)
VITE_API_BASE_URL=http://localhost:8000

# Origem do WebSocket (socket.io). Namespace /game é anexado pelo client.
# Kong ainda não roteia o WS no contrato — aponte direto para o Game Service
# (ex: http://localhost:4001) caso o gateway não exponha /socket.io.
VITE_WS_URL=http://localhost:8000

# Keycloak (OIDC authorization code flow + PKCE S256)
VITE_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/crash-game
VITE_KEYCLOAK_CLIENT_ID=crash-game-client
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/callback
VITE_KEYCLOAK_POST_LOGOUT_URI=http://localhost:5173
