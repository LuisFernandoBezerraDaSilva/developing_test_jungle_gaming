PORT=4001
DATABASE_URL=postgresql://admin:admin@postgres:5432/games
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672
REDIS_URL=redis://redis:6379
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=crash-game
# Admin (realm master) usado para resolver usernames via Admin API — ver CONTRACT §0
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Modo determinístico (bônus, opcional — ver docker-compose.e2e.yml) --------
# Deixe em branco em produção. Setados, tornam as rodadas reprodutíveis:
#   GAME_FIXED_SERVER_SEED        — serverSeed fixo (hash/crash reproduzíveis)
#   GAME_FORCE_CRASH_MULTIPLIER   — força o crash (ex: 1.50); SÓ teste, quebra /verify
#   GAME_BETTING_WINDOW_SECONDS   — janela de apostas (default 10)
GAME_FIXED_SERVER_SEED=
GAME_FORCE_CRASH_MULTIPLIER=
GAME_BETTING_WINDOW_SECONDS=10
