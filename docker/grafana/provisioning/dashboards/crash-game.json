  "panels": [
    {
      "type": "stat",
      "title": "RTP (creditado / apostado)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 } },
      "targets": [
