generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Round {
  id               String   @id @default(uuid())
  phase            String   @default("BETTING")
  serverSeed       String
  serverHash       String
  clientSeed       String   @default("crash-game-public-seed")
  nonce            Int
  crashMultiplier  String?
  phaseStartedAt   DateTime @default(now())
  crashedAt        DateTime?
  settledAt        DateTime?
  createdAt        DateTime @default(now())
  bets             Bet[]

  @@map("rounds")
}

model Bet {
  id                String   @id @default(uuid())
  roundId           String
  playerId          String
  amountCents       BigInt
  status            String   @default("PENDING")
  cashoutMultiplier String?
  payoutCents       BigInt?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  round             Round    @relation(fields: [roundId], references: [id])

  @@unique([roundId, playerId])
  @@map("bets")
}
